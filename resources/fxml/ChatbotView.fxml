<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gymflow.controller.ChatbotController"
      styleClass="chatbot-root"
      stylesheets="@../css/chatbot.css"
      spacing="0">

    <!-- ── Header ──────────────────────────────────────────────────────────── -->
    <HBox styleClass="chat-header" alignment="CENTER_LEFT" spacing="10">
        <HBox.margin><Insets/></HBox.margin>
        <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>

        <StackPane>
            <Circle radius="18" styleClass="bot-avatar-circle"/>
            <Label text="🤖" style="-fx-font-size: 18;"/>
        </StackPane>

        <VBox spacing="2">
            <Label text="Assistant Marketing" styleClass="header-title"/>
            <HBox alignment="CENTER_LEFT" spacing="5">
                <Circle fx:id="statusDot" radius="5" styleClass="status-offline"/>
                <Label fx:id="statusLabel" text="Vérification..." styleClass="status-label"/>
            </HBox>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <Button text="🗑 Effacer" onAction="#clearChat" styleClass="clear-button"/>
    </HBox>

    <!-- ── Messages area ───────────────────────────────────────────────────── -->
    <ScrollPane fx:id="scrollPane"
                VBox.vgrow="ALWAYS"
                fitToWidth="true"
                hbarPolicy="NEVER"
                styleClass="chat-scroll">

        <VBox fx:id="messagesContainer"
              styleClass="messages-container"
              spacing="10">
            <padding><Insets top="16" right="0" bottom="16" left="0"/></padding>
        </VBox>
    </ScrollPane>

    <!-- ── Typing indicator ────────────────────────────────────────────────── -->
    <HBox fx:id="typingIndicator"
          styleClass="typing-row"
          alignment="CENTER_LEFT"
          spacing="8"
          visible="false"
          managed="false">
        <padding><Insets top="6" right="20" bottom="6" left="20"/></padding>
        <Label text="●●●" styleClass="typing-dots"/>
        <Label text="L'assistant réfléchit..." styleClass="typing-text"/>
    </HBox>

    <!-- ── Input bar ───────────────────────────────────────────────────────── -->
    <HBox styleClass="input-bar" alignment="CENTER" spacing="10">
        <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>

        <TextField fx:id="inputField"
                   HBox.hgrow="ALWAYS"
                   promptText="Posez votre question marketing…"
                   styleClass="chat-input"/>

        <Button fx:id="sendButton"
                text="Envoyer ➤"
                onAction="#sendMessage"
                styleClass="send-button"
                defaultButton="true"/>
    </HBox>

</VBox>
