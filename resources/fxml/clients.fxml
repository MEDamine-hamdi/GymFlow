<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gymflow.controller.ClientController"
      spacing="30"
      styleClass="root">

    <!-- LEFT: ADD CLIENT -->
    <VBox spacing="15"
          styleClass="login-box"
          prefWidth="300"
          minWidth="300">

        <Label text="Ajouter Client" styleClass="title"/>

        <TextField fx:id="nomField" promptText="Nom" styleClass="input"/>
        <TextField fx:id="prenomField" promptText="Prénom" styleClass="input"/>
        <TextField fx:id="telephoneField" promptText="Téléphone" styleClass="input"/>

        <!-- ✅ ADD COMBOBOX HERE -->
        <ComboBox fx:id="abonnementComboBox"
                  promptText="Choisir abonnement"
                  styleClass="input"/>

        <Button text="Ajouter"
                onAction="#handleAddClient"
                styleClass="login-button"/>
    </VBox>

    <!-- RIGHT: TABLE -->
    <VBox spacing="15"
          HBox.hgrow="ALWAYS"
          VBox.vgrow="ALWAYS">

        <!-- HEADER -->
        <HBox spacing="20" alignment="CENTER_LEFT">
            <Label text="Liste des Clients" styleClass="title"/>

            <TextField fx:id="searchField"
                       promptText="Rechercher..."
                       styleClass="input"
                       prefWidth="250"/>
        </HBox>

        <!-- ✅ THIS IS THE IMPORTANT FIX -->
        <TableView fx:id="clientTable"
                   VBox.vgrow="ALWAYS"
                   prefHeight="600">

            <columns>
                <TableColumn fx:id="nomColumn" text="Nom" prefWidth="120"/>
                <TableColumn fx:id="prenomColumn" text="Prénom" prefWidth="120"/>
                <TableColumn fx:id="telColumn" text="Téléphone" prefWidth="150"/>
                <TableColumn fx:id="abonnementColumn" text="Abonnement" prefWidth="150"/>
                <TableColumn fx:id="actionColumn" text="Actions" prefWidth="150"/>
            </columns>

        </TableView>

    </VBox>

</HBox>