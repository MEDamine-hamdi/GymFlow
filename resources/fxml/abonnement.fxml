<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<HBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gymflow.controller.AbonnementController"
      styleClass="root">

    <!-- LEFT FORM -->
    <VBox spacing="15" styleClass="login-box" prefWidth="300">

        <Label text="Ajouter Abonnement" styleClass="title"/>

        <TextField fx:id="nameField"
                   promptText="Nom abonnement"
                   styleClass="input"/>

        <TextField fx:id="priceField"
                   promptText="Prix"
                   styleClass="input"/>

        <Button text="Ajouter"
                onAction="#handleAdd"
                styleClass="login-button"/>

    </VBox>

    <!-- RIGHT TABLE -->
    <VBox spacing="6" HBox.hgrow="ALWAYS">

        <Label text="Liste des abonnements" styleClass="title"/>

        <TableView fx:id="table">

            <columns>

                <TableColumn text="Nom" fx:id="nameCol" prefWidth="200"/>
                <TableColumn text="Prix" fx:id="priceCol" prefWidth="150"/>
                <TableColumn text="Actions" fx:id="actionCol" prefWidth="200"/>

            </columns>

        </TableView>

    </VBox>

</HBox>